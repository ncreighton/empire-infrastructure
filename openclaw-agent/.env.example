# ============================================================================
# OpenClaw Agent — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# Lines starting with # are comments. Remove the # to enable a variable.

# ─── Brand Identity ─────────────────────────────────────────────────────────
# These define the profile content used across all 46 platforms.

OPENCLAW_BRAND_NAME=OpenClaw
OPENCLAW_EMAIL=your-email@example.com
OPENCLAW_USERNAME=openclaw
OPENCLAW_WEBSITE=https://your-website.com
OPENCLAW_TAGLINE=AI agents & automation tools

# ─── Brand Assets ───────────────────────────────────────────────────────────
# Paths to avatar and banner images used during profile creation.

OPENCLAW_AVATAR_PATH=
OPENCLAW_BANNER_PATH=

# ─── Social Links ───────────────────────────────────────────────────────────
# Social profiles linked from platform bios. Leave blank to omit.

OPENCLAW_GITHUB=
OPENCLAW_TWITTER=
OPENCLAW_LINKEDIN=
OPENCLAW_YOUTUBE=
OPENCLAW_SUBSTACK=

# ─── SEO & Voice ────────────────────────────────────────────────────────────
# Comma-separated keywords injected into profile bios for discoverability.
# Brand voice controls tone: professional, casual, technical, friendly.

OPENCLAW_SEO_KEYWORDS=AI,automation,agents,tools,workflows
OPENCLAW_BRAND_VOICE=professional

# ─── Security ───────────────────────────────────────────────────────────────
# Fernet symmetric key for encrypting stored credentials (passwords, tokens).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

OPENCLAW_ENCRYPTION_KEY=

# ─── Email Verification ─────────────────────────────────────────────────────
# IMAP credentials for the EmailVerifier module. It watches the inbox for
# verification emails from platforms and auto-clicks the confirmation links.

OPENCLAW_IMAP_HOST=imap.gmail.com
OPENCLAW_IMAP_PORT=993
OPENCLAW_EMAIL_PASSWORD=

# ─── Proxy Rotation ─────────────────────────────────────────────────────────
# Comma-separated proxy URLs for the ProxyManager. Supports http, https, socks5.
# Example: http://user:pass@host:port,socks5://host2:1080

OPENCLAW_PROXIES=

# ─── Webhooks & Dashboard ───────────────────────────────────────────────────
# Webhook endpoint for signup event notifications (POST JSON payloads).
# Dashboard URL points to the Empire dashboard alerts API for real-time alerts.

OPENCLAW_WEBHOOK_URL=
OPENCLAW_DASHBOARD_URL=

# ─── CAPTCHA Solving ────────────────────────────────────────────────────────
# 2Captcha API key for automatic reCAPTCHA/hCaptcha/Turnstile solving.
# Without this, CAPTCHAs are queued for manual human solving via the API.

TWOCAPTCHA_API_KEY=

# ─── LLM (Browser Agent) ────────────────────────────────────────────────────
# Anthropic API key used by the ExecutorAgent for browser-use visual navigation.
# Only the ExecutorAgent calls the LLM; all other modules are algorithmic.

ANTHROPIC_API_KEY=
