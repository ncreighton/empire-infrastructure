# VideoForge API Keys Template
# Copy to api_keys.env and fill in your keys

# Creatomate — Video rendering
CREATOMATE_API_KEY=your_creatomate_key_here

# OpenRouter — AI script generation
OPENROUTER_API_KEY=your_openrouter_key_here

# FAL.ai — AI image generation
FAL_KEY=your_fal_key_here

# Pexels — Free stock video/photos
PEXELS_API_KEY=your_pexels_key_here

# Pixabay — Free music
PIXABAY_API_KEY=your_pixabay_key_here

# YouTube Data API (for publishing)
YOUTUBE_API_KEY=your_youtube_key_here

# TikTok (for publishing)
TIKTOK_CLIENT_KEY=your_tiktok_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_secret_here
