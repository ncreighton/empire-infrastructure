          "id": "existing-empire-postgres",
          "name": "Empire Architect Postgres"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO brain_learnings (content, source, category, confidence, content_hash) VALUES ($1, $2, $3, $4, md5($1)) ON CONFLICT (content_hash) DO UPDATE SET times_referenced = brain_learnings.times_referenced + 1, updated_at = NOW()",
        "options": {}
      },
      "id": "pg-upsert-learnings",
