# Empire Brain Telegram Commander Bot
# Copy to .env and fill in values

# Telegram (created via @BotFather)
TELEGRAM_COMMANDER_TOKEN=
TELEGRAM_ADMIN_IDS=  # comma-separated Telegram user IDs

# Brain MCP (Windows machine via Tailscale)
BRAIN_MCP_URL=http://100.x.x.x:8200

# Dashboard (same VPS)
DASHBOARD_URL=http://localhost:8000

# n8n (same VPS)
N8N_URL=http://localhost:5678
N8N_API_KEY=

# Docker (local socket)
DOCKER_HOST=unix:///var/run/docker.sock

# WordPress sites config path (optional override)
SITES_CONFIG_PATH=/app/config/sites.json

# Timezone for scheduled jobs
TZ=America/New_York
